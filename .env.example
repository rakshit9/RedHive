# ---- LLM provider (the brain of every agent) ----
# "openai" (default) or "claude"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic / Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Database ----
DATABASE_URL=postgresql://redhive:redhive@localhost:5432/redhive

# ---- Scope guard ----
# Comma-separated PRACTICE hosts that are always scannable without ownership
# verification (intentionally-vulnerable demo apps). Customer hosts are
# authorized per-org via verified Target records, NOT this list.
SCAN_ALLOWLIST=localhost,127.0.0.1,juiceshop,host.docker.internal

# ---- Auth / security ----
# Signs dashboard session tokens. MUST be a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string
# Dashboard session lifetime, minutes (default one week).
SESSION_TTL_MINUTES=10080

# ---- Target ownership verification ----
# DNS TXT record prefix customers add to prove they own a host.
OWNERSHIP_DNS_PREFIX=_redhive-verify

# ---- CORS ----
# Browser origins allowed to call the API (the Next.js dashboard).
# Never use "*" together with credentials.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Plan quotas (free tier) ----
FREE_TARGET_LIMIT=3
FREE_MONTHLY_SCAN_LIMIT=50
